# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Google Gemini API Key (get from https://aistudio.google.com/)
GEMINI_API_KEY=AIzaSyA_example_key_here

# Allowed Telegram chat IDs (comma-separated, empty = reject all - secure by default)
# Leave empty to block all groups. Add chat IDs to allow specific groups:
ALLOWED_CHAT_IDS=

# ---------------------------------------------------------------------------
# Market Summary Feature (optional)
# ---------------------------------------------------------------------------

# CoinGecko Demo API key (optional, get free key at https://www.coingecko.com/en/api)
# Without a key the public rate-limited endpoint is used (still works for daily use)
COINGECKO_API_KEY=

# Newsdata.io API key (optional, get free key at https://newsdata.io/)
# If empty, the news section is omitted from the market summary
NEWSDATA_API_KEY=

# Daily market summary schedule
# Time is in the timezone specified by MARKET_SUMMARY_TIMEZONE
# Set MARKET_SUMMARY_HOUR=-1 to disable the scheduled job (still accessible via /marketsummary)
MARKET_SUMMARY_HOUR=8
MARKET_SUMMARY_MINUTE=0
MARKET_SUMMARY_TIMEZONE=UTC

# Chat IDs to send the daily scheduled summary to (comma-separated)
# Defaults to all ALLOWED_CHAT_IDS if left empty
MARKET_SUMMARY_CHAT_IDS=
